# Server Port
PORT=3000

# AI Provider Selection (choose one: 'openai', 'deepseek', 'gemini', 'groq')
VITE_AI_PROVIDER=groq

# OpenAI Configuration
VITE_OPENAI_API_KEY=sk-proj-your-openai-api-key-here
VITE_OPENAI_ASSISTANT_ID=asst_your-assistant-id-here
VITE_OPENAI_THREAD_ID=thread_your-thread-id-here

# DeepSeek Configuration
VITE_DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# Gemini Configuration
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# Groq Configuration (free tier, very fast, great for coding)
# Get a free API key at https://console.groq.com/keys
VITE_GROQ_API_KEY=gsk_your-groq-api-key-here

# System Prompt (optional - will use default if not set)
VITE_SYSTEM_PROMPT=
